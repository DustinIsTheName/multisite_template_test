{%- comment -%}
  Parameters:
  - product {Object} - Product object.
  - class {String} - CSS Class (optional)
  - use_variant {Boolean} - Use variant price instead of general (optional, default is false).
  - current_variant {Object} - Current variant, if use_variant is true.

  Usage:
  {% render 'price', product: product %}
{%- endcomment -%}

{%- liquid
  assign variant = current_variant | default: product.variants | sort: 'price' | first

  if use_variant
    if current_variant == false
      assign available = true
    endif
  else
    assign use_variant = false
    assign available = variant.available | default: false
  endif

  assign compare_at_price = variant.compare_at_price
  assign price = variant.price | default: 1999
-%}

<div class="price{%- if compare_at_price > price %} price--on-sale{% endif -%}
                 {%- if available == false %} price--sold-out{% endif -%}{% if class %} {{ class }}{% endif %}">
  <div class="price__default">
    <span class="price__current">
      <span class="visually-hidden js-label">
        {%- if compare_at_price and compare_at_price > price -%}
          {{- 'products.product.price.sale_price' | t -}}
        {%- else -%}
          {{- 'products.product.price.regular_price' | t -}}
        {%- endif -%}
      </span>
      {%- if product.price_varies -%}
        {%- if use_variant == false -%}
          <span class="price__from">{{ 'products.product.from' | t }}</span>
        {%- elsif use_variant and current_variant == false -%}
          <span class="price__from">{{ 'products.product.from' | t }}</span>
        {%- endif -%}
      {%- endif %}
      <span class="js-value">
        {%- render 'price-as-money', price: price -%}
      </span>
    </span>
    <span class="price__was{% if settings.superscript_decimals %} price__was--supercents{% endif %}">
      <span class="visually-hidden js-label">
        {%- if compare_at_price and compare_at_price > price -%}
          {{- 'products.product.price.regular_price' | t -}}
        {%- endif -%}
      </span>
      <span class="js-value">
        {%- if compare_at_price and compare_at_price > price -%}
          {%- render 'price-as-money', price: compare_at_price, show_money_with_currency: false -%}
        {%- endif -%}
      </span>
    </span>
  </div>

  {%- liquid
    assign unit_price_money = variant.unit_price | money
    capture unit_price_formatted
      render 'price-as-money', price: variant.unit_price, show_money_with_currency: false
    endcapture
  -%}
  <div class="unit-price relative"{% if variant.unit_price_measurement == nil %} hidden{% endif %}><span class="visually-hidden">{{ 'products.product.price.unit_price' | t }}</span><span>{{ variant.unit_price | unit_price_with_measurement: variant.unit_price_measurement | replace: unit_price_money, unit_price_formatted }}</span></div>
</div>
