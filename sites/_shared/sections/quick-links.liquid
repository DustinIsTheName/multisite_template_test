{%- if section.blocks.size > 0 -%}
  {%- if section.index > 2 and section.location != 'header' -%}
    <link rel="stylesheet" href="{{ 'quick-links.css' | asset_url }}" media="print" onload="this.media='all'">
  {%- else -%}
    {{ 'quick-links.css' | asset_url | stylesheet_tag }}
  {%- endif -%}

  <script src="{{ 'quick-links.js' | asset_url }}" defer="defer"></script>

  {%- liquid
    assign color_scheme = section.settings.color_scheme

    if section.settings.num_rows > 0
      assign is_clipped = true
    else
      assign is_clipped = false
    endif
  -%}

  {%- unless section.settings.full_width -%}
    <div class="container">
  {%- endunless -%}

  <div class="section{% if section.settings.full_width %} section--full-width{% if section.settings.dividers != 'none' %} {{ section.settings.dividers }}{% endif %}{% endif %} section--padded-{{ section.settings.section_height }}{% unless color_scheme == 'none' %} color-scheme color-scheme--{{ color_scheme }}{% endunless %}" id="{{ section.id }}">
    <div class="container relative">
      {%- if section.settings.heading != blank -%}
        <h2 class="h4 section__heading {{ section.settings.heading_align }}"{% if settings.animations_enabled != 'disabled' and section.settings.prevent_animation == false %} data-cc-animate{% endif %}>{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      <quick-links class="quick-links{% if is_clipped %} quick-links--clipped{% endif %}{% if section.settings.mobile_carousel %} quick-links--carousel{% endif %}"
        {%- if is_clipped %} data-show-more-text="{{ 'sections.quick_links.show_more' | t | escape }}" data-show-less-text="{{ 'sections.quick_links.show_less' | t | escape }}"{% endif %}
        {%- if settings.animations_enabled != 'disabled' and section.settings.prevent_animation == false %} data-cc-animate{% endif %}
        style="--gap-multiplier: {{ section.settings.gap_multiplier }};{% if is_clipped %} --row-count: {{ section.settings.num_rows }};{% endif %}">
        <ul class="quick-links__list {{ section.settings.content_align }}" role="list">
          {%- for block in section.blocks -%}
            {%- if block.settings.text != blank -%}
              {%- liquid
                assign button_style = section.settings.button_style
                if block.settings.change_button_style
                  assign button_style = block.settings.button_style
                endif
              -%}
              <li {{ block.shopify_attributes }}>
                <a class="quick-links__item {{ button_style }}" {% if block.settings.link == blank %}role="link" aria-disabled="true"{% else %}href="{{ block.settings.link }}"{% endif %}>
                  {{- block.settings.text | escape -}}
                </a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>

        {%- if is_clipped -%}
          <div class="quick-links__footer {{ section.settings.content_align }}">
            <button class="quick-links__toggle {{ section.settings.toggle_style }}" type="button">
              {{- 'sections.quick_links.show_more' | t -}}
            </button>
          </div>
        {%- endif -%}
      </quick-links>
    </div>
  </div>

  {%- unless section.settings.full_width -%}
    </div>
  {%- endunless -%}
{%- endif -%}

{% schema %}
{
  "name": "Quick links",
  "tag": "section",
  "class": "cc-quick-links",
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_align",
      "label": "Heading alignment",
      "options": [
        {
          "value": "text-start",
          "label": "Left"
        },
        {
          "value": "text-center",
          "label": "Center"
        },
        {
          "value": "text-end",
          "label": "Right"
        }
      ],
      "default": "text-center"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "label": "Section height",
      "id": "section_height",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "xsmall",
          "label": "Extra small"
        },
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        }
      ],
      "default": "medium"
    },
    {
      "type": "range",
      "id": "num_rows",
      "label": "Number of rows shown by default",
      "info": "Set to 0 to show all.",
      "min": 0,
      "max": 5,
      "step": 1,
      "default": 1
    },
    {
      "type": "select",
      "label": "Gap",
      "id": "gap_multiplier",
      "options": [
        {
          "value": "1",
          "label": "Extra small"
        },
        {
          "value": "2",
          "label": "Small"
        },
        {
          "value": "4",
          "label": "Medium"
        },
        {
          "value": "6",
          "label": "Large"
        }
      ],
      "default": "2"
    },
    {
      "type": "checkbox",
      "id": "mobile_carousel",
      "label": "Show as a carousel on mobile",
      "default": true
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        {
          "value": "btn btn--primary",
          "label": "Primary button"
        },
        {
          "value": "btn btn--secondary",
          "label": "Secondary button"
        }
      ],
      "default": "btn btn--primary"
    },
    {
      "type": "select",
      "id": "toggle_style",
      "label": "Show more button style",
      "options": [
        {
          "value": "link",
          "label": "Link"
        },
        {
          "value": "btn btn--primary",
          "label": "Primary button"
        },
        {
          "value": "btn btn--secondary",
          "label": "Secondary button"
        }
      ],
      "default": "link"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Content alignment",
      "options": [
        {
          "value": "justify-start",
          "label": "Left"
        },
        {
          "value": "justify-center",
          "label": "Center"
        },
        {
          "value": "justify-end",
          "label": "Right"
        }
      ],
      "default": "justify-center"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        {
          "value": "none",
          "label": "Default"
        },
        {
          "value": "1",
          "label": "Scheme 1"
        },
        {
          "value": "2",
          "label": "Scheme 2"
        },
        {
          "value": "3",
          "label": "Scheme 3"
        }
      ],
      "default": "1"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Make section background full width",
      "default": true
    },
    {
      "type": "select",
      "id": "dividers",
      "label": "Dividing lines when full width",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "border-top",
          "label": "Above"
        },
        {
          "value": "border-bottom",
          "label": "Below"
        },
        {
          "value": "border-top border-bottom",
          "label": "Above and below"
        }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "SEO"
    },
    {
      "type": "checkbox",
      "id": "prevent_animation",
      "label": "Load the section without animation",
      "info": "If this section is visible when the page loads, enabling this setting can reduce CLS and may improve site speed scores. [Read more](https://cleancanvas.co.uk/support/enterprise/performance-guide)",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Link",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Link text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "change_button_style",
          "label": "Change button style",
          "default": false
        },
        {
          "visible_if": "{{ block.settings.change_button_style }}",
          "type": "select",
          "id": "button_style",
          "label": "Button style",
          "options": [
            {
              "value": "btn btn--primary",
              "label": "Primary button"
            },
            {
              "value": "btn btn--secondary",
              "label": "Secondary button"
            }
          ],
          "default": "btn btn--secondary"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Quick links",
      "category": "Feature",
      "blocks": [
        {
          "type": "link",
          "settings": {
            "text": "Link text"
          }
        },
        {
          "type": "link",
          "settings": {
            "text": "Link text"
          }
        },
        {
          "type": "link",
          "settings": {
            "text": "Link text"
          }
        },
        {
          "type": "link",
          "settings": {
            "text": "Link text"
          }
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": [
      "aside"
    ]
  }
}
{% endschema %}
